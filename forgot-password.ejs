<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | Campus OLX</title>
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🎓</text></svg>" />
</head>
<body>

<!-- NAVBAR -->
<nav class="navbar">
  <div class="navbar-inner">
    <a href="/" class="navbar-brand">Campus <span>OLX</span></a>

    <form class="navbar-search" action="/" method="GET">
      <input type="text" name="search" placeholder="Search products..." value="<%= typeof filters !== 'undefined' && filters.search ? filters.search : '' %>" />
      <button type="submit">🔍</button>
    </form>

    <button class="hamburger" id="hamburger">☰</button>

    <div class="navbar-nav" id="navLinks">
      <% const currentUser = typeof user !== 'undefined' ? user : null; %>
      <% if (currentUser) { %>
        <% if (currentUser.is_admin) { %>
          <a href="/admin/dashboard" class="nav-link" style="color:#6c63ff;font-weight:700">⚙️ Admin Panel</a>
        <% } else { %>
          <a href="/products/new" class="nav-link btn-post-nav">+ Sell</a>
          <a href="/products/favorites" class="nav-link">❤️ Saved</a>
          <a href="/messages" class="nav-link">💬 Messages</a>
          <a href="/profile" class="nav-link">👤 <%= currentUser.full_name.split(' ')[0] %></a>
        <% } %>
        <a href="/auth/logout" class="nav-link">Logout</a>
      <% } else { %>
        <a href="/auth/login" class="nav-link">Login</a>
        <a href="/auth/signup" class="nav-link btn-post-nav">Sign Up</a>
      <% } %>
      <button class="dark-toggle" id="themeToggle" title="Toggle dark mode">🌙</button>
    </div>
  </div>
</nav>

<!-- FLASH MESSAGES -->
<% const flashSuccess = typeof success !== 'undefined' ? success : []; %>
<% const flashError = typeof error !== 'undefined' ? error : []; %>
<% if (flashSuccess && flashSuccess.length > 0) { %>
  <div class="flash-container">
    <% flashSuccess.forEach(msg => { %>
      <div class="flash flash-success">✅ <%= msg %></div>
    <% }) %>
  </div>
<% } %>
<% if (flashError && flashError.length > 0) { %>
  <div class="flash-container">
    <% flashError.forEach(msg => { %>
      <div class="flash flash-error">⚠️ <%= msg %></div>
    <% }) %>
  </div>
<% } %>
