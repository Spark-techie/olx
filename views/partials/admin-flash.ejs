<% if (typeof success !== 'undefined' && success && success.length) { %>
  <div class="flash flash-success"><i class="fas fa-check-circle"></i> <%= Array.isArray(success) ? success[0] : success %></div>
<% } %>
<% if (typeof error !== 'undefined' && error && error.length) { %>
  <div class="flash flash-error"><i class="fas fa-exclamation-circle"></i> <%= Array.isArray(error) ? error[0] : error %></div>
<% } %>
