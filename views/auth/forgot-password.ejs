<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Forgot Password | KR Mart</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
<div class="auth-page">
  <div class="auth-card">
    <div class="auth-logo"><a href="/">KR <span>Mart</span></a></div>
    <h1 class="auth-title">Reset Password</h1>
    <p class="auth-subtitle">Enter your college email to get a reset link</p>

    <% if (success && success.length) { %>
      <% success.forEach(msg => { %><div class="flash flash-success mb-2">✅ <%= msg %></div><% }) %>
    <% } %>
    <% if (error && error.length) { %>
      <% error.forEach(msg => { %><div class="flash flash-error mb-2">⚠️ <%= msg %></div><% }) %>
    <% } %>

    <form method="POST" action="/auth/forgot-password">
      <div class="form-group">
        <label class="form-label">College Email</label>
        <input type="email" name="email" class="form-control" placeholder="you@krct.ac.in" required />
      </div>
      <button type="submit" class="btn btn-primary btn-block">Send Reset Link</button>
    </form>
    <div class="auth-divider">remember your password?</div>
    <a href="/auth/login" class="btn btn-outline btn-block">Back to Login</a>
  </div>
</div>
<script src="/js/main.js"></script>
</body>
</html>
