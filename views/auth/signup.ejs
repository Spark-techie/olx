<%
function timeAgo() {}
function categoryIcon() {}
%>
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sign Up | KR Mart</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
<div class="auth-page">
  <div class="auth-card">
    <div class="auth-logo">
      <a href="/">KR <span>Mart</span></a>
    </div>
    <h1 class="auth-title">Create Account</h1>
    <p class="auth-subtitle">Join your college marketplace</p>

    <div class="college-badge">
      🎓 Only college emails accepted<br>
      <strong>@krct.ac.in · @krce.ac.in · @mkec.ac.in</strong>
    </div>

    <% if (error && error.length > 0) { %>
      <% error.forEach(msg => { %>
        <div class="flash flash-error mb-2">⚠️ <%= msg %></div>
      <% }) %>
    <% } %>

    <form method="POST" action="/auth/signup">
      <div class="form-group">
        <label class="form-label">Full Name</label>
        <input type="text" name="full_name" class="form-control" placeholder="e.g. Jawaharlal M" required />
      </div>
      <div class="form-group">
        <label class="form-label">College Email</label>
        <input type="email" name="email" class="form-control" placeholder="you@krct.ac.in" required />
        <p class="form-hint">Must be a college email address</p>
      </div>
      <div class="form-group">
        <label class="form-label">Phone Number (Optional)</label>
        <input type="tel" name="phone" class="form-control" placeholder="9876543210" />
      </div>
      <div class="form-group">
        <label class="form-label">Password</label>
        <input type="password" name="password" class="form-control" placeholder="Minimum 6 characters" required minlength="6" />
      </div>
      <div class="form-group">
        <label class="form-label">Confirm Password</label>
        <input type="password" name="confirm_password" class="form-control" placeholder="Repeat your password" required />
      </div>
      <button type="submit" class="btn btn-primary btn-block btn-lg">Create Account →</button>
    </form>

    <div class="auth-divider">already have an account?</div>
    <a href="/auth/login" class="btn btn-outline btn-block">Login</a>
  </div>
</div>
<script src="/js/main.js"></script>
</body>
</html>
