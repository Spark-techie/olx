<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <%- include('../partials/admin-style') %>
</head>
<body>
<%- include('../partials/admin-sidebar', {page}) %>
<div class="main">
  <%- include('../partials/admin-topbar') %>
  <div class="content">
    <%- include('../partials/admin-flash') %>

    <div class="page-row">
      <div class="section-title">👥 Users <span><%= total %> TOTAL</span></div>
      <form class="search-form" method="GET" action="/admin/users">
        <input class="input" name="search" placeholder="Search name or email..." value="<%= search %>"/>
        <button class="btn btn-primary" type="submit"><i class="fas fa-search"></i> Search</button>
        <% if (search) { %><a href="/admin/users" class="btn btn-ghost">Clear</a><% } %>
      </form>
    </div>

    <div class="table-card">
      <table>
        <thead>
          <tr>
            <th>User</th><th>Email</th><th>College</th><th>Status</th><th>Joined</th><th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach(u => { %>
          <tr>
            <td>
              <div style="display:flex;align-items:center;gap:10px;">
                <div class="avatar-sm"><%= u.full_name.charAt(0).toUpperCase() %></div>
                <div>
                  <div style="font-weight:600;font-size:.85rem"><%= u.full_name %></div>
                  <% if (u.is_admin) { %><span class="badge badge-purple" style="font-size:.6rem">Admin</span><% } %>
                </div>
              </div>
            </td>
            <td class="mono" style="font-size:.78rem"><%= u.email %></td>
            <td><span class="badge badge-purple"><%= u.college_name.split(' ')[0] %></span></td>
            <td>
              <% if (u.is_banned) { %>
                <span class="badge badge-red"><i class="fas fa-ban"></i> Banned</span>
              <% } else { %>
                <span class="badge badge-green"><i class="fas fa-check"></i> Active</span>
              <% } %>
            </td>
            <td class="mono" style="font-size:.75rem;color:var(--text3)"><%= new Date(u.created_at).toLocaleDateString() %></td>
            <td>
              <% if (!u.is_admin) { %>
                <div style="display:flex;gap:6px;flex-wrap:wrap;">
                  <% if (!u.is_banned) { %>
                    <button class="btn btn-warning btn-sm" onclick="openBanModal(<%= u.id %>, '<%= u.full_name.replace(/'/g,'') %>')">
                      <i class="fas fa-ban"></i> Ban
                    </button>
                  <% } else { %>
                    <form method="POST" action="/admin/users/<%= u.id %>/unban" style="display:inline">
                      <button class="btn btn-success btn-sm"><i class="fas fa-check"></i> Unban</button>
                    </form>
                  <% } %>
                  <button class="btn btn-danger btn-sm" onclick="confirmDelete(<%= u.id %>, '<%= u.full_name.replace(/'/g,'') %>')">
                    <i class="fas fa-trash"></i>
                  </button>
                </div>
              <% } else { %>
                <span style="color:var(--text3);font-size:.78rem">Protected</span>
              <% } %>
            </td>
          </tr>
          <% }) %>
          <% if (!users.length) { %>
          <tr><td colspan="6"><div class="empty"><i class="fas fa-users"></i><p>No users found</p></div></td></tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <% if (totalPages > 1) { %>
    <div class="pagination">
      <% for(let i=1;i<=totalPages;i++) { %>
        <a href="?page=<%= i %>&search=<%= search %>" class="page-btn <%= currentPage===i?'active':'' %>"><%= i %></a>
      <% } %>
    </div>
    <% } %>
  </div>
</div>

<!-- Ban Modal -->
<div class="modal-overlay" id="banModal">
  <div class="modal">
    <h3>🚫 Ban User: <span id="banUserName"></span></h3>
    <form id="banForm" method="POST">
      <div class="form-group">
        <label>Reason for ban</label>
        <textarea class="input" name="reason" rows="3" placeholder="Explain why this user is being banned...">Violation of campus marketplace rules</textarea>
      </div>
      <div class="modal-actions">
        <button type="button" class="btn btn-ghost" onclick="closeModal('banModal')">Cancel</button>
        <button type="submit" class="btn btn-danger"><i class="fas fa-ban"></i> Ban User</button>
      </div>
    </form>
  </div>
</div>

<!-- Delete confirmation -->
<form id="deleteUserForm" method="POST" style="display:none"></form>

<script>
function openBanModal(id, name) {
  document.getElementById('banUserName').textContent = name;
  document.getElementById('banForm').action = `/admin/users/${id}/ban`;
  openModal('banModal');
}
function confirmDelete(id, name) {
  if (confirm(`Delete user "${name}"? This will also remove all their listings.`)) {
    const f = document.getElementById('deleteUserForm');
    f.action = `/admin/users/${id}/delete`;
    f.submit();
  }
}
document.querySelectorAll('.modal-overlay').forEach(el => {
  el.addEventListener('click', e => { if(e.target===el) el.classList.remove('open'); });
});
function openModal(id){ document.getElementById(id).classList.add('open'); }
function closeModal(id){ document.getElementById(id).classList.remove('open'); }
</script>
</body>
</html>
