<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Reset Password | Campus OLX</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
<div class="auth-page">
  <div class="auth-card">
    <div class="auth-logo"><a href="/">Campus <span>OLX</span></a></div>
    <h1 class="auth-title">New Password</h1>
    <p class="auth-subtitle">Enter your new password below</p>

    <% if (error && error.length) { %>
      <% error.forEach(msg => { %><div class="flash flash-error mb-2">⚠️ <%= msg %></div><% }) %>
    <% } %>

    <form method="POST" action="/auth/reset-password/<%= token %>">
      <div class="form-group">
        <label class="form-label">New Password</label>
        <input type="password" name="password" class="form-control" placeholder="Minimum 6 characters" required minlength="6" />
      </div>
      <div class="form-group">
        <label class="form-label">Confirm New Password</label>
        <input type="password" name="confirm_password" class="form-control" placeholder="Repeat new password" required />
      </div>
      <button type="submit" class="btn btn-primary btn-block">Reset Password</button>
    </form>
  </div>
</div>
<script src="/js/main.js"></script>
</body>
</html>
